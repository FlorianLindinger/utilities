{
  // =====================================
  // general 
  "breadcrumbs.enabled": true,
  "files.autoSave": "afterDelay",
  "window.newWindowProfile": "Default",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.list.mouseWheelScrollSensitivity": 2,
  "workbench.browser.showInTitleBar": false,
  // =====================================
  // terminal
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  // =====================================
  // explorer
  "explorer.excludeGitIgnore": false,
  "explorer.confirmDelete": false,
  "files.exclude": { // not visible in explorer:
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/.gitattributes": true,
    "**/LICENSE": true,
    "**/*.lnk": true,
    "**/*.lprof": true,
    "**/*.pid": true,
    "**/*.ome.tif": true,
    "**/*.tiff": true,
  },
  // =====================================
  // default formatters
  "editor.formatOnSave": true,
  "notebook.formatOnSave.enabled": true,
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  }, // if "C/C++" extension installed
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  }, // if "C/C++" extension installed
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "notebook.defaultFormatter": "charliermarsh.ruff",
  // =====================================
  // git & diff
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 180, //seconds
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "git.postCommitCommand": "push",
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.maxComputationTime": 0,
  "diffEditor.hideUnchangedRegions.enabled": true,
  // =====================================
  // editor  
  "editor.codeLens": true,
  "editor.showFoldingControls": "always",
  "editor.foldingStrategy": "auto",
  "editor.suggest.showStatusBar": true,
  "editor.mouseWheelZoom": true,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.hover.delay": 800,
  "editor.mouseWheelScrollSensitivity": 3,
  // =====================================
  // notebooks
  "notebook.compactView": true,
  "notebook.lineNumbers": "on",
  "notebook.stickyScroll.enabled": true,
  "notebook.cellExecutionTimeVerbosity": "verbose",
  "notebook.cellFocusIndicator": "border",
  "notebook.dragAndDropEnabled": true,
  "notebook.diff.overviewRuler": true,
  "notebook.globalToolbarShowLabel": "dynamic",
  "notebook.insertToolbarLocation": "hidden", // insert cell button
  "notebook.output.scrolling": true,
  "notebook.output.wordWrap": true,
  "notebook.showCellStatusBar": "visible",
  "notebook.variablesView": true,
  "jupyter.widgetScriptSources": [
    "jsdelivr.com",
    "unpkg.com"
  ], //needed for interactive
  "jupyter.askForKernelRestart": false,
  "[jupyter]": {
    "editor.mouseWheelScrollSensitivity": 3.5
  },
  "notebook.cellToolbarLocation": {
    "default": "hidden"
  },
  "notebook.editorOptionsCustomizations": {
    "editor.tabSize": 4,
    "editor.indentSize": 4,
    "editor.insertSpaces": true
  },
  // =====================================
  // vscode
  "settingsSync.ignoredExtensions": [],
  "settingsSync.ignoredSettings": [],
  // =====================================
  // copilot/chat/AI
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "python": true
  },
  "chat.titleBar.openInAgentsWindow.enabled": false,
  "chat.tools.terminal.autoApprove": {
    "/^python -m py_compile live_plot\\.py$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cd \"c:\\\\Users\\\\agpup\\\\Documents\\\\Repositories\\\\fieldmax_power_meter_python\" ; python -m py_compile live_plot\\.py$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },
  // =====================================
  // Python
  "python.defaultInterpreterPath": "C:\\Users\\Flo\\Documents\\python_envs\\default_env\\Scripts\\python.exe",
  "python.venvFolders": [
    "Documents\\python_envs"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.experiments.optOutFrom": [
    "All"
  ],
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.inlayHints.functionReturnTypes": false,
  "python.analysis.autoImportCompletions": false,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "never"
    },
  },
  // =====================================
  // java
  "js/ts.tsserver.watchOptions": "vscode",
  "jdk.telemetry.enabled": false,
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-25",
      "path": "C:\\Program Files\\Java\\jdk-25.0.2",
      "default": true
    }
  ],
  // =====================================
  // autodocstring
  "autoDocstring.docstringFormat": "numpy",
  "autoDocstring.customTemplatePath": "utilities\\python related\\python_autodocstring_extension_template.mustache",
  // =====================================
  // gitlens (if "gitlens" extension installed)
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  // =====================================
  // Ruff formatter/linter settings (python)
  "ruff.nativeServer": "on",
  "ruff.configuration": "~\\Documents\\Repositories\\utilities\\python related\\good_Ruff_settings.toml",
  "ruff.configurationPreference": "filesystemFirst", //"filesystemFirst" "editorFirst"
  "ruff.lint.enable": true,
  "ruff.lint.preview": false,
  "ruff.logLevel": "info",
  // =====================================
  // type checker settings (general)
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.venv/**": true
  },
  // =====================================
  // pyrefly - type checker and LSP (alternative to pylance)
  "python.languageServer": "None", //"None" == pyrefly ; "Default"=Pylance
  "python.pyrefly.typeCheckingMode": "default", //"off"/"basic"/"auto"/"default"/"strict"
  "python.pyrefly.disableTypeErrors": false,
  "python-envs.globalSearchPaths": [
    "${env:USERPROFILE}\\Documents\\python_envs"
  ],
  // =====================================
  // buttons in GUI using "commands"-extension
  "commands.commands": {
    "Pyrefly type checking": {
      "nestedItems": {
        "Auto": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "auto",
            "target": "workspace"
          }
        },
        "Off": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "off",
            "target": "workspace"
          }
        },
        "Basic": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "basic",
            "target": "workspace"
          }
        },
        "Legacy": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "legacy",
            "target": "workspace"
          }
        },
        "Default": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "default",
            "target": "workspace"
          }
        },
        "Strict": {
          "command": "commands.toggleSetting",
          "args": {
            "setting": "python.pyrefly.typeCheckingMode",
            "value": "strict",
            "target": "workspace"
          }
        }
      },
      "statusBar": {
        "alignment": "right",
        "name": "Pyrefly type checking",
        "text": "Pyrefly: ${config:python.pyrefly.typeCheckingMode} $(chevron-down)",
        "tooltip": "Select Pyrefly type-checking mode",
        "activeEditorLanguage": "python",
        "updateEvents": [
          {
            "kind": "onDidConfigurationChange",
            "settings": [
              "python.pyrefly.typeCheckingMode"
            ]
          }
        ]
      }
    }
  }
  // =====================================
  // <-- new setting
}